# ===========================================================================
# ai-ops-automation-control-plane :: environment template
# Copy to `.env` and fill in real values. `.env` is gitignored.
#   cp .env.example .env
# ===========================================================================

# --- General ---------------------------------------------------------------
TZ=UTC

# --- LLM provider keys (at least one required for RAG / extraction) ---------
OPENAI_API_KEY=sk-replace-me
ANTHROPIC_API_KEY=sk-ant-replace-me

# Which provider the tools service uses by default: openai | anthropic
LLM_PROVIDER=openai
# Chat/answer model
LLM_MODEL=gpt-4o-mini
# Embedding model + dimensionality (must match the documents.embedding column)
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# --- Postgres --------------------------------------------------------------
POSTGRES_USER=aiops
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=aiops
# Used by the tools service; host is the compose service name `postgres`.
DATABASE_URL=postgresql://aiops:change-me-strong-password@postgres:5432/aiops

# --- n8n -------------------------------------------------------------------
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me-strong-password
N8N_HOST=localhost
WEBHOOK_URL=http://localhost:5678/

# --- Tools service ---------------------------------------------------------
TOOLS_BASE_URL=http://tools:8000
# Confidence threshold below which /answer flags for human review (0..1).
RAG_LOW_CONFIDENCE_THRESHOLD=0.35

# --- Integrations (placeholders; wired in n8n credentials) -----------------
SLACK_BOT_TOKEN=xoxb-replace-me
SLACK_DEFAULT_CHANNEL=#ops
SLACK_HR_CHANNEL=#hr
GMAIL_USER=ops@example.com
GMAIL_APP_PASSWORD=replace-me
